generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String         @id @default(cuid())
  clerkId            String         @unique
  email              String         @unique
  name               String?
  vaultPath          String
  onboardingComplete Boolean        @default(false)
  importStatus       String?
  // Weekly credit allotment. 1 credit = $0.01 of API spend.
  // 500 credits = $5/week budget.
  credits            Int            @default(500)
  creditsResetAt     DateTime       @default(now())
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  conversations      Conversation[]
  simulations        Simulation[]
  vaultFiles         VaultFile[]
  usageEvents        UsageEvent[]
  settings           UserSettings?
}

/// Ledger of every LLM call for observability + debugging.
/// Lets us see what a user actually spent credits on.
model UsageEvent {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action       String   // "chat" | "import" | "simulation.lens" | "simulation.run" | ...
  model        String
  inputTokens  Int
  outputTokens Int
  credits      Int      // credits charged for this event
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model UserSettings {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id])
  preferredModel String  @default("claude-sonnet-4-6")
  memoryEnabled  Boolean @default(true)
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String?
  mode      String   @default("chat")
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VaultFile {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  path      String   // e.g. "_index.md", "people/alice.md"
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, path])
  @@index([userId])
}

model Simulation {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  title            String
  scenario         String
  narrative        String?
  timeHorizonYears Int
  status           String   @default("pending")
  // "pending" | "generating_lenses" | "ready_to_run" | "running"
  // | "generating_report" | "complete" | "failed"
  lenses           Json     @default("[]")
  runs             Json     @default("[]")
  report           Json?
  error            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId, createdAt])
}
